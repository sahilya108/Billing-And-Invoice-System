@model IEnumerable<BillingAndInvoiceSystem.Models.Product>

@using BillingAndInvoiceSystem.Helpers
@using BillingAndInvoiceSystem.Models

@{
    var role = Context.Session.GetString("UserRole");
    var cart = Context.Session.GetObjectFromJson<List<CartItem>>("Cart") ?? new List<CartItem>();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (ViewBag.Message != null)
{
    <div class="alert alert-warning mt-2">
        @ViewBag.Message
    </div>
}

<h2>
    @(role == "Admin" ? "Manage Products" : "Product List")
</h2>

<form asp-action="Search" method="get" class="mb-3">
    <input type="text" name="searchTerm" placeholder="Search product by name" class="form-control" />
    <br />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (role == "Admin")
{
    <a asp-action="Create" class="btn btn-primary">Add Product</a>

    <a asp-controller="Billing" asp-action="StartBilling" class="btn btn-success ms-2">
        Create Billing
    </a>
}
else if (role == "Staff")
{
    <a asp-controller="Cart" asp-action="Index" class="btn btn-warning">
        Go to Cart
    </a>
}

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>

            @if (role == "Admin")
            {
                <th>Actions</th>
            }
            else
            {
                <th>Cart</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            var inCart = cart.Any(c => c.ProductId == item.Id);

            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.Stock</td>

                @if (role == "Admin")
                {
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this product?');">
                            Delete
                        </a>
                    </td>
                }

                @if (role == "Staff")
                {
                    <td>
                        @if (inCart)
                        {
                            <button class="btn btn-secondary btn-sm" disabled>
                                Added
                            </button>
                        }
                        else
                        {
                            <a asp-action="AddToCart" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                                Add to Cart
                            </a>
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</table>