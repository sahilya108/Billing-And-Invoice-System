<h2>Billing Dashboard</h2>

<!-- Show Selected Customer -->
@if (ViewBag.CustomerName != null)
{
    <div class="alert alert-info">
        Selected Customer: <strong>@ViewBag.CustomerName</strong>
    </div>
}
else
{
    <div class="alert alert-warning">
        No customer selected ❌
    </div>
}

<!-- Navigation Buttons -->
<div class="mt-3">

    <a asp-controller="Customer" asp-action="Index" class="btn btn-primary">
        Select Customer
    </a>

    <a asp-controller="Product" asp-action="Index" class="btn btn-success">
        Add Products
    </a>

    <a asp-controller="Cart" asp-action="Index" class="btn btn-warning">
        View Cart
    </a>

</div>