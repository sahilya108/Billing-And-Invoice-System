<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BillingAndInvoiceSystem</title>

   
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    

</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow mb-3">
            <div class="container-fluid">

                <!-- BRAND -->
                <a class="navbar-brand text-light fw-bold" asp-controller="Home" asp-action="Index">
                    BillingAndInvoiceSystem
                </a>

                <!-- TOGGLE -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @{
                    var role = Context.Session.GetString("UserRole");
                }

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">

                        <!-- COMMON -->
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (!string.IsNullOrEmpty(role))
                        {
                            <!-- ADMIN -->
                            @if (role == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Product" asp-action="Index">Manage Products</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Customer" asp-action="Index">Manage Customers</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="User" asp-action="StaffList">Manage Staff</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-success" asp-controller="Billing" asp-action="StartBilling">Create Billing</a>
                                </li>
                            }

                            <!-- STAFF -->
                            @if (role == "Staff")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Staff" asp-action="Index">Dashboard</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Customer" asp-action="Index">Customers</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-primary" asp-controller="Billing" asp-action="Index">Billing</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Product" asp-action="Index">Products</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-success" asp-controller="Cart" asp-action="Index">Cart</a>
                                </li>
                            }

                            <!-- LOGOUT -->
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="User" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary" asp-controller="User" asp-action="Login">Login</a>
                            </li>
                        }

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- DARK FOOTER -->
    <footer class="footer bg-dark text-light mt-auto">
        <div class="container text-center py-3">
            © 2026 Billing & Invoice System | Designed by Team SRV
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
