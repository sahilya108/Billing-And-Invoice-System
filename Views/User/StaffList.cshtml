@model IEnumerable<BillingAndInvoiceSystem.Models.User>

<h2>Manage Staff</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Role</td>

                <td>
                    <a asp-action="EditStaff" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="DeleteStaff"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Delete this staff?');">
                        Delete
                    </a>

                    <a asp-action="ChangePassword" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                        Change Password
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>