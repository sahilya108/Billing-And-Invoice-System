@model IEnumerable<BillingAndInvoiceSystem.Models.Customer>

@{
    var role = Context.Session.GetString("UserRole");
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<h2>
    @(role == "Admin" ? "Manage Customers" : "Customer List")
</h2>

<!-- SEARCH -->
<form asp-action="Search" method="get" class="mb-3">
    <input type="text" name="searchTerm" placeholder="Search by name or phone" class="form-control" />
    <br />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

<!-- ADD BUTTON -->
@if (role == "Admin" || role == "Staff")
{
    <a asp-action="Create" class="btn btn-success">Add Customer</a>
}

@if (ViewBag.Message != null)
{
    <div class="alert alert-warning mt-2">
        @ViewBag.Message
    </div>
}

@if (Model.Any())
{
    <table class="table table-bordered mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>

                @if (role == "Admin")
                {
                    <th>Actions</th>
                }
                else
                {
                    <th>Action</th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Phone</td>

                    <!-- ADMIN -->
                    @if (role == "Admin")
                    {
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this customer?');">
                                Delete
                            </a>
                        </td>
                    }

                    <!-- STAFF -->
                    @if (role == "Staff")
                    {
                        <td>
                            <a asp-action="Select" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                Select
                            </a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}