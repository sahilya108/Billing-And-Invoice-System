@model List<BillingAndInvoiceSystem.Models.CartItem>

<h2>Shopping Cart</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Cart is empty 
    </div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th> 
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Price</td>

                    <!-- UPDATE QUANTITY -->
                    <td>
                        <form asp-action="UpdateQuantity" method="post" style="display:inline;">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" style="width:70px;" />
                            <button type="submit" class="btn btn-sm btn-primary">Update</button>
                        </form>
                    </td>

                    <td>@item.TotalPrice</td>

                    <!-- REMOVE BUTTON -->
                    <td>
                        <a asp-action="Remove" asp-route-productId="@item.ProductId" class="btn btn-danger btn-sm">
                            Remove
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h4>
        Grand Total: @Model.Sum(x => x.TotalPrice)
    </h4>
}