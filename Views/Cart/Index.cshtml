@model List<BillingAndInvoiceSystem.Models.CartItem>

<h2>Shopping Cart</h2>

<!--  SUCCESS MESSAGE -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<!--  ERROR MESSAGE -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Cart is empty 
    </div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Price</td>

                    <!-- UPDATE QUANTITY -->
                    <td>
                        <form asp-action="UpdateQuantity" method="post" style="display:inline;">
                            <input type="hidden" name="productId" value="@item.ProductId" />

                            <!-- min=1 -->
                            <input type="number"
                                   name="quantity"
                                   value="@item.Quantity"
                                   min="1"
                                   class="form-control d-inline"
                                   style="width:80px;" />

                            <button type="submit" class="btn btn-sm btn-primary">
                                Update
                            </button>
                        </form>
                    </td>

                    <td>@item.TotalPrice</td>

                    <!-- REMOVE -->
                    <td>
                        <a asp-action="Remove"
                           asp-route-productId="@item.ProductId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Remove this item?');">
                            Remove
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- GRAND TOTAL -->
    <h4 class="mt-3">
        Grand Total: @Model.Sum(x => x.TotalPrice)
    </h4>

    <!-- ACTION BUTTONS -->
    <div class="mt-3">
        <a asp-action="ClearCart" class="btn btn-secondary">
            Clear Cart
        </a>

        <a asp-action="Checkout" class="btn btn-success ms-2">
            Checkout
        </a>
    </div>
}