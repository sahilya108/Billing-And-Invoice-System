@model BillingAndInvoiceSystem.Models.Invoice

<div class="container mt-4">

    <div class="card shadow p-4">

        <div class="d-flex justify-content-between align-items-center">
            <h2>Invoice</h2>

            <button onclick="window.print()" class="btn btn-success">
                Print Invoice
            </button>
        </div>

        <hr />

        <!-- COMPANY INFO -->
        <div class="row">
            <div class="col-md-6">
                <h4>BillingAndInvoiceSystem</h4>
                <p>Invoice No: @Model.InvoiceNumber</p>
                <p>Date: @Model.Date</p>
            </div>

            <div class="col-md-6 text-end">
                <p><strong>Customer:</strong> @Model.CustomerName</p>
                <p><strong>Billed By:</strong> @Model.BillerName</p>
            </div>
        </div>

        <hr />

        <!-- PRODUCT TABLE -->
        <table class="table table-bordered mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Price</td>
                        <td>@item.Quantity</td>
                        <td>@(item.Price* item.Quantity)</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- BILL SUMMARY -->
        <div class="row justify-content-end mt-4">
            <div class="col-md-4">

                <p><strong>Total Amount:</strong> @Model.TotalAmount</p>

                @if (Model.DiscountAmount > 0)
                {
                    <p><strong>Discount:</strong> -@Model.DiscountAmount</p>
                }

                @if (Model.DiscountPercent > 0)
                {
                    <p><strong>Discount (%):</strong> @Model.DiscountPercent %</p>
                }

                <hr />

                <h4><strong>Final Amount: @Model.FinalAmount</strong></h4>
            </div>
        </div>

        <hr />

        <!-- FOOTER -->
        <div class="text-center mt-3">
            <p>Thank you for your business</p>
        </div>

    </div>
</div>

<!-- PRINT STYLE -->
<style>
    @@media print {
        button

    {
        display: none;
    }

    body {
        margin: 0;
    }

    .card {
        box-shadow: none;
        border: none;
    }

    }
</style>